rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se o usuário é admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Regras para a coleção de usuários
    match /users/{userId} {
      // O usuário pode ler seu próprio perfil ou um admin pode ler todos
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Criar: só se for o próprio e não for admin
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.isAdmin == false;
      
      // Atualizar: o próprio usuário pode, desde que não mude isAdmin e email. Admins podem tudo.
      allow update: if request.auth != null && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'email'])) || 
        isAdmin()
      );
      
      // Deletar: apenas admins
      allow delete: if request.auth != null && isAdmin();
    }

    // Regras para o Currículo/Checklist
    match /curriculum/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Regras para Flashcards
    match /flashcards/{cardId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Regras para Itens do Checklist (se houver coleção separada)
    match /checklist_items/{itemId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
